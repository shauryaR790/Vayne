# Copy to repo root as `.env` (gitignored) — required for Ask VAYNE analyst.
# NEVER put VAYNE_LLM_API_KEY in NEXT_PUBLIC_* or any frontend env file.

VAYNE_LLM_PROVIDER=openai
VAYNE_LLM_API_KEY=sk-your-key-here
VAYNE_LLM_MODEL=gpt-4.1-mini
VAYNE_LLM_TEMPERATURE=0.7
VAYNE_LLM_MAX_OUTPUT_TOKENS=800
VAYNE_LLM_MAX_CONTEXT_CHARS=10000

# Free-tier Ask VAYNE message cap (server-enforced; includes section asks)
VAYNE_FREE_CHAT_LIMIT=4

# Backend storage (SQLite dev — no Postgres required)
DATABASE_URL=sqlite:///product/storage/vayne_dev.db
VAYNE_STORAGE=product/storage/investigations
