<?xml version="1.0"?>
<nmaprun scanner="nmap">
  <host>
    <address addr="10.0.0.12" addrtype="ipv4"/>
    <hostnames><hostname name="edge.example.com"/></hostnames>
    <ports>
      <port protocol="tcp" portid="443">
        <state state="open"/>
        <service name="http" product="Apache httpd" version="2.4.49"/>
      </port>
    </ports>
  </host>
  <host>
    <address addr="10.0.0.55" addrtype="ipv4"/>
    <hostnames><hostname name="assets.example.com"/></hostnames>
    <ports>
      <port protocol="tcp" portid="443">
        <state state="open"/>
        <service name="https" product="AmazonS3"/>
      </port>
    </ports>
  </host>
</nmaprun>
